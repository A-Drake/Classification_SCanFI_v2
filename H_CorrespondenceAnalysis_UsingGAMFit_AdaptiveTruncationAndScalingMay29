############################################################
# Set up and fill matrix with Jaccard Similarity values ----
###########################################################

groupshape<-list()
spav<-hc<-list()

for (j in c(1:length(Varlist))){ # start covariate
VarSmooth<-sub[[j]]

    mat<-matrix(
    nrow=ncol(VarSmooth),
    ncol=ncol(VarSmooth),
    dimnames=list(names(VarSmooth),names(VarSmooth))
    )

  for(v in seq_len(ncol(VarSmooth))){
    for(w in seq_len(ncol(VarSmooth))){ 
      #Jaccard similarity (AnB/A+B-AnB)= AnB/AuB
      #Standardized so the selection area will sum to 1 for each spp x BCR 
      s<-VarSmooth[,c(v,w)]%>%data.frame()
      trunc<-!is.na(s[,1]+s[,2]) #ID overlap areas of curve
      s<-s%>%.[c(which(trunc)),] #retain only overlap areas
      s[,1]<-s[,1]/sum(s[,1]) #scale 1 within shared range
      s[,2]<-s[,2]/sum(s[,2]) #scale 2 within shared range
      summed<-colSums(abs(s))%>%sum(.) #A+B == 2 if truncated and standardized
      s<-subset(s,sign(s[,1])==sign(s[,2]))%>%abs(.) # get absolute values where the direction of selection matches
      ind<-sum(pmin(s[1], s[2]),na.rm=T) # AnB (overlap is the minimum value in shared direction)
      mat[v,w]<-(ind/(summed-ind)) # calc. Jaccard similarlity for only shared overlap regions....
    }
    per<-w/ncol(VarSmooth)
    print((v+per)/ncol(VarSmooth))
    } # Jaccard similarity done ----
  
  spav[[j]]<-mat # for averaging within species
  print(paste(Varlist[j],"done"))

  # Convert to Jaccard Distance ----  
  Jdist<-as.dist(1-mat)
  View(mat)
  # Visualize ---
  hc[[j]] <- hclust(Jdist, method = "average")  # for splitting into clusters
} # finished Jaccard

