# View outputs -----
library(ggplot2)
library(forcats)

data_ordered <- combined_data %>%
  # Reorder species levels by the mean of m_DevDiff across all BCRs
  mutate(species = fct_reorder(species, l95_DevDiff, .fun = mean, .desc = TRUE))

# Define a custom signed square root transformation function
signed_sqrt_trans <- function() {
  trans_new(
    name = "signed_sqrt",
    transform = function(x) sign(x) * sqrt(abs(x)),
    inverse = function(x) sign(x) * (x^2)
  )
}



# Define a consistent dodge width so points and error bars align perfectly
dodge_width <- 0.3 

ggplot(data_ordered, aes(x = species, y = Dev_Diff, color = BCR)) +

  geom_hline(yintercept = 0, linetype = "dashed", color = "gray50", 
             linewidth = 0.6) +
  scale_y_continuous(trans = signed_sqrt_trans()) +  
  #95% Quantile Intervals
  geom_errorbar(
    aes(ymin = l95_DevDiff, ymax = u95_DevDiff),
    position = position_dodge(width = dodge_width),
    width = 0.3,         # Width of the horizontal caps on the error bars
    linewidth = 0.3,
    alpha = 0.8
  ) +
  
  # Plot the Mean Delta Deviance points
  geom_point(position = position_dodge(width = dodge_width),
    size = 1, stroke = 0.5) +
  
  # Labels and Styling
  labs(title = "Out-of-Sample Delta Deviance by Species and BCR",
    subtitle = "Positive values favor the Full Model; Intervals crossing 0 indicate equivalence",
    x = "Species",
    y = expression(Delta * " Deviance (Reduced - Full)"),
    color = "Bird Conservation\nRegion (BCR)"
  ) +
  
  theme_minimal(base_size = 12) +
  theme(
    panel.grid.minor = element_blank(),
    panel.grid.major.x = element_blank(), # Cleans up categorical x-axis space
    axis.text.x = element_text(angle = 90, hjust = 1), # Tilts species codes
    legend.position = "right",
    plot.title = element_text(face = "bold", size = 14),
    plot.subtitle = element_text(color = "gray30", size = 10)
  )


