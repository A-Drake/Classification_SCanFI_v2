  if(!is.matrix(simmat%>% .[, grepl(spp[p], colnames(.))])){ # if species only in 1 BCR and therefore no comparison
  means[p]<-NA
  n[p]<-1
  next
  } 

similarities<-simmat %>% .[, grepl(spp[p], colnames(.))] %>% .[grepl(spp[p], rownames(.)), ]
means[p]<-(sum(similarities)-sqrt(length(similarities)))/(length(similarities)-sqrt(length(similarities))) # sum matrix, remove the diagonal (sum of 1s) and divide by count minus diagonal (curves identical with themselves)
n[p]<-sqrt(length(similarities))

} #done species

# tabulate
sim[[j]]<-data.frame(species=spp, Var=Varlist[j], means=means, n=n)
} # done covariate

