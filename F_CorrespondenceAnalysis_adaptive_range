############################################################
# Set up and fill matrix with Jaccard Similarity values ----
###########################################################

groupshape<-list()
spav<- list()
hc<-list()

for (j in seq_along(Varlist)){ # start covariate
VarSmooth<-sub[[j]]
n_col <- ncol(VarSmooth)

    mat<-matrix(
    nrow=n_col,
    ncol=n_col,
    dimnames=list(names(VarSmooth),names(VarSmooth))
    )
#Jaccard similarity (AnB/A+B-AnB)= AnB/AuB
  for(v in seq_len(n_col)){
    for(w in v:n_col){ 
      
  # extract selection curve pair
      s<-VarSmooth[,c(v,w)]
  #retain only overlap areas
      s <- s[!is.na(s[, 1]) & !is.na(s[, 2]), ] 
  #A+B == 2 if truncated and restandardized
      summed<- sum(abs(s), na.rm = TRUE) 
  # get absolute values where the direction of selection matches
      s_shared <- s[sign(s[, 1]) == sign(s[, 2]), , drop = FALSE]
      s_shared <- abs(s_shared) 
  # AnB (overlap is the sum of the minimum values in a shared direction)
      ind <- sum(pmin(s_shared[, 1], s_shared[, 2]), na.rm = TRUE) 
# Calculate Jaccard similarity with edge-case handling   
      if (summed == 0) {
        value<- 1  # If both curves are empty/zero, they are identical
      } else if ((summed - ind) == 0) {
        value<- 0  # Prevent division by zero for non-overlapping data
      } else {
        value<- ind / (summed - ind)# calc. Jaccard similarlity for only shared overlap regions....
      } # done if statement
      mat[v,w] <- mat[w,v] <- value # assign mirror values to 1/2 compute time
    } # end of w loop
  
  #track progress  
  cat(sprintf("Covariate %d (%s) - Progress: %.1f%%\r", j, Varlist[j], (v / n_col) * 100))
    
  } # end of v loop

  spav[[j]]<-mat # for averaging within species
  print(paste(Varlist[j],"done"))

  # Convert to Jaccard Distance ----  
  mat_clamped <- pmax(pmin(mat, 1), 0)
  Jdist <- as.dist(1 - mat_clamped)

  # Visualize ---
  hc[[j]] <- hclust(Jdist, method = "average")  # for splitting into clusters
} # finished Jaccard

