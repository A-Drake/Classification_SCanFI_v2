# ----------------------------------------------
# Mathematical approaches to splitting groups
# ---------------------------------------------

for (j in seq_along(Varlist)){
  
# Extract the merging heights in reverse order (from top of the tree down)
heights <- rev(hc[[j]]$height)

# Calculate the differences between consecutive merges (velocity of changes)
diffs <- diff(heights)

# Find the point of maximum change acceleration 
# Adding 1 or 2 to the index aligns it back to the corresponding K clusters
optimal_k <- which.max(abs(diffs)) + 1

cat(sprintf("Optimal K for %s based on tree height acceleration: %d\n", Varlist[j],optimal_k))

heights <- hc[[j]]$height

# 2. Calculate the mean and standard deviation of those heights
mean_h <- mean(heights)
sd_h   <- sd(heights)

# 3. Set Mojena's constant
k_constant <- 3.5

# 4. Calculate the threshold height line
threshold <- mean_h + (k_constant * sd_h)

# 5. Determine K (the number of branches that cross this threshold)
# It equals the total number of objects minus how many joins happened below the line, plus 1
num_objects <- length(hc[[j]]$order)
joins_below_threshold <- sum(heights < threshold)
optimal_k <- num_objects - joins_below_threshold

cat(sprintf("Mojena's Criterion suggests splitting %s into K = %d clusters.\n",Varlist[j], optimal_k))
}

