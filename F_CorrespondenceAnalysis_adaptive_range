  # If species is only present in 1 BCR, there are no pairwise comparisons to average
  if (spp_count <= 1) {
    means[p] <- NA
    n[p]     <- 1
    next
  } 
  
  # Subset the square matrix for just this species
  sub_mat <- simmat[spp_match, spp_match, drop = FALSE]
  pairwise_similarities <- sub_mat[lower.tri(sub_mat)]
  means[p] <- mean(pairwise_similarities, na.rm = TRUE)
  n[p]     <- spp_count

} #done species
  
  # Tabulate results
  sim[[j]] <- data.frame(
    species = spp, 
    Var     = Varlist[j], 
    means   = means, 
    n       = n
  )
